#!/usr/bin/env python3
import os
import sys
import argparse
import json
from datetime import datetime, timezone
from urllib.request import Request, urlopen
from urllib.error import HTTPError, URLError
from urllib.parse import urlencode

ALL_STATES = ["published", "draft", "triage", "closed"]

RESET = "\033[0m"
BOLD = "\033[1m"

STATE_COLORS = {
    "draft": "\033[36m",  # cyan
    "triage": "\033[33m",  # yellow
    "published": "\033[32m",  # green
    "closed": "\033[2m",  # grey
}


def plasma(t):
    """Plasma color: t=0 → purple (old), t=1 → yellow (recent)."""
    r = int(13 + (253 - 13) * t)
    g = int(8 + (231 - 8) * t)
    b = int(135 + (37 - 135) * t)
    return f"\033[38;2;{r};{g};{b}m"


def age_t(date_str):
    dt = datetime.fromisoformat(date_str.replace("Z", "+00:00"))
    age = (datetime.now(timezone.utc) - dt).days
    return max(0.0, 1.0 - age / 365)


def block(date_str):
    color = plasma(age_t(date_str)) if date_str else ""
    return f"{color}█{RESET}"


GITHUB_API = "https://api.github.com"


def check_token():
    token = os.environ.get("GITHUB_TOKEN")
    if not token:
        print("error: GITHUB_TOKEN environment variable not set", file=sys.stderr)
        sys.exit(1)
    return token


def parse_next_link(link_header):
    """Parse RFC 5988 Link header and return the 'next' URL, or None."""
    if not link_header:
        return None
    for part in link_header.split(","):
        segments = part.strip().split(";")
        if len(segments) < 2:
            continue
        url = segments[0].strip().lstrip("<").rstrip(">")
        for seg in segments[1:]:
            if seg.strip() == 'rel="next"':
                return url
    return None


def fetch(org, state, token):
    url = (
        f"{GITHUB_API}/orgs/{org}/security-advisories"
        f"?{urlencode({'state': state, 'per_page': 100})}"
    )
    headers = {
        "Authorization": f"Bearer {token}",
        "Accept": "application/vnd.github+json",
        "X-GitHub-Api-Version": "2026-03-10",
        "User-Agent": "security-overview",
    }
    results = []
    while url:
        print(f"[GET] {url}", file=sys.stderr)
        try:
            with urlopen(Request(url, headers=headers)) as resp:
                body = resp.read().decode("utf-8")
                link = resp.headers.get("Link")
        except HTTPError as e:
            msg = e.read().decode("utf-8", errors="replace").strip()
            print(f"[error] {org} ({state}): HTTP {e.code} {msg}", file=sys.stderr)
            return results
        except URLError as e:
            print(f"[error] {org} ({state}): {e.reason}", file=sys.stderr)
            return results
        try:
            page = json.loads(body) if body.strip() else []
        except json.JSONDecodeError:
            return results
        if isinstance(page, list):
            results.extend(page)
        url = parse_next_link(link)
    return results


def print_org(org, states, token):
    advisories = []
    for state in states:
        advisories.extend(fetch(org, state, token))
    print(f"\n{BOLD}=== {org} ==={RESET}")
    if not advisories:
        print("  (no advisories)")
        return

    by_repo = {}
    for advisory in advisories:
        repo = (advisory.get("html_url") or "").split("/")[4] or "unknown"
        by_repo.setdefault(repo, []).append(advisory)

    advisories_by_repo = sorted(
        by_repo.items(),
        key=lambda x: max(a.get("updated_at", "") for a in x[1]),
        reverse=True,
    )

    for repo, items in advisories_by_repo:
        items = sorted(items, key=lambda a: a.get("updated_at", ""), reverse=True)
        print(f"{repo}")
        for advisory in items:
            date = advisory.get("updated_at", "")
            title = (advisory.get("summary") or "")[:50].ljust(50)
            state_val = advisory.get("state") or "?"
            state_col = STATE_COLORS.get(state_val, "")
            state_str = f"{state_col}{state_val.ljust(10)}{RESET}"
            url = advisory.get("html_url", "")
            url_base, _, url_id = url.rpartition("/")
            url_fmt = f"{state_col}\033[2m{url_base}/\033[22m{url_id}{RESET}"
            days_ago = (
                (
                    datetime.now(timezone.utc)
                    - datetime.fromisoformat(date.replace("Z", "+00:00"))
                ).days
                if date
                else "?"
            )
            print(
                f"   {block(date)} {str(days_ago).rjust(4)}d  {title}  {state_str}   {url_fmt}"
            )


def main():
    token = check_token()
    parser = argparse.ArgumentParser(prog="security-overview")
    parser.add_argument("orgs", nargs="+", metavar="org")
    parser.add_argument(
        "--state",
        choices=ALL_STATES,
        action="append",
        metavar="STATE",
        help="filter by state (repeatable, default: all states)",
    )
    args = parser.parse_args()
    states = args.state or ALL_STATES
    for org in args.orgs:
        print_org(org, states, token)
    print()


if __name__ == "__main__":
    main()
